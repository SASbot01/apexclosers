# ── Recall.ai (grabación + transcripción) ─────────────────────────────
RECALL_API_KEY=
RECALL_API_URL=https://eu-central-1.recall.ai

# ── Supabase (almacenamiento de llamadas) ─────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Google OAuth (calendario del closer → invitación automática) ───────
# El closer conecta su Google en el login (scope calendar.readonly). El cron
# /api/calendar?action=schedule-bots lee sus calendarios y programa el bot de
# Recall para cada llamada de VENTA inminente (ver callClassifier). Sin estas
# claves, no hay lectura de calendario ni invitación automática.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Anthropic (resumen + feedback del Orbe) ───────────────────────────
# Opcional si usas el LLM local (Ollama). Si OLLAMA_URL está definido, el
# finalize usa el LLM local y NO llama a Anthropic.
ANTHROPIC_API_KEY=

# ── IA LOCAL (abaratar costes) ────────────────────────────────────────
# LLM local via Ollama (resumen/feedback/outcome). Si está definido, sustituye
# a Anthropic en api/recall.js → finalize.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
# STT local via Whisper (local-ai/whisper_server.py). Si está definido:
#  - el bot de Recall deja de pedir transcripción (solo graba)
#  - finalize transcribe en local desde recording_url
LOCAL_STT_URL=http://127.0.0.1:8090

# ── Base pública (para que el webhook dispare finalize en background) ──
# En Vercel: https://tu-deploy.vercel.app
APEX_PUBLIC_BASE_URL=

# ── Frontend (Vite) ───────────────────────────────────────────────────
# Usuario único en Fase 0 (dogfooding). En Fase 1 lo da el login.
VITE_USER_ID=00000000-0000-0000-0000-000000000001
# Base del API (vacío = mismo origen, p.ej. en Vercel). En dev local sin
# backend, las páginas caen a datos mock automáticamente.
VITE_API_BASE=
